#!/bin/bash
# S30-PRO Federation: Mission Control Loop (v2.6.0)
# Objective: Full cycle automation including Postflight FITS Verification.

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT" || exit

echo "🔬 [POSTFLIGHT] Auditing Last Night's FITS Evidence..."
# Scans the Seestar storage for FITS files and verifies headers
python3 core/postflight/fits_auditor.py

echo "🌅 [MORNING] Initiating Reconciliation & Briefing..."
# Only reconciles targets verified by the auditor
python3 core/preflight/librarian.py --reconcile

echo "🧛 [EVENING] Slicing the 9-Day Backlog..."
python3 core/preflight/librarian.py

echo "🛰️ [FLIGHT] Handing over to Flightmaster..."
python3 core/flight/orchestrator.py

echo "✅ [STATUS] Mission Cycle Complete. FITS Verified."
